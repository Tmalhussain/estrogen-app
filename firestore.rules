rules_version = '2';

// =============================================================================
// Estrogen Pharmacy — Firestore Security Rules
// Locked by /plan-eng-review on 2026-05-05.
// Source of truth for v1+v1.5 schema in CLAUDE.md.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isPharmacist() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'pharmacist';
    }

    function isStaff() {
      return isAdmin() || isPharmacist();
    }

    // Pharmacist scoped to a branch (v2 multi-store). v1 = "main".
    function isPharmacistForBranch(branchId) {
      return isPharmacist() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId == branchId
         || isAdmin());
    }

    // Has the requesting user been granted consent to access targetUserId's data?
    // v1: schema-only check, no UX exposure. v2 caregiver mode reads this.
    function hasConsentFrom(targetUserId, scope) {
      // Look up an active consent_grant where targetUserId granted the
      // requesting user access for the given scope. Read-only check; the
      // Cloud Function side enforces consent record creation/revocation.
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/consent_grants/$(targetUserId + '_' + request.auth.uid + '_' + scope));
    }

    // ── Users ────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Addresses subcollection (existing)
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // ── Family / multi-profile (v1 schema, v2 UX) ────────
      // Each user has at least one profile (themselves). v2 caregiver mode
      // adds dependent profiles (mom, daughter, etc.).
      match /family/{profileId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isOwner(userId);
      }

      // FCM device tokens (push notifications) — existing convention
      match /fcmTokens/{tokenId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ── Products ─────────────────────────────────────────────
    // Anyone can browse. Multi-store: every product carries branchId.
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Categories ───────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Orders ───────────────────────────────────────────────
    // Customer reads their own orders; staff reads orders within their branch.
    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid
         || isPharmacistForBranch(resource.data.branchId)
         || isAdmin());

      // Customer creates an order — branchId is required, userId must match,
      // status must start at 'placed' (server may upgrade in the trigger).
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll(['userId', 'branchId', 'status']) &&
        request.resource.data.status in ['placed', 'pending_review'];

      // Staff may update status. Customer may cancel from limited states.
      allow update: if (
        // Staff in the same branch can update most fields
        isPharmacistForBranch(resource.data.branchId)
        || isAdmin()
        // Customer cancellation only
        || (isOwner(resource.data.userId)
            && request.resource.data.status == 'cancelled'
            && resource.data.status in ['placed', 'pending_review', 'pharmacist_review'])
      );

      allow delete: if isAdmin();
    }

    // ── Prescriptions ────────────────────────────────────────
    match /prescriptions/{prescriptionId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid
         || isPharmacistForBranch(resource.data.branchId)
         || isAdmin());

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll(['userId', 'branchId', 'status']);

      allow update: if (
        isPharmacistForBranch(resource.data.branchId)
        || isAdmin()
        || (isOwner(resource.data.userId)
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['fileName', 'storageUrl']))
      );

      allow delete: if isAdmin();
    }

    // ── Subscriptions (v1.5 — auto-refill) ──────────────────
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid
         || isPharmacistForBranch(resource.data.branchId)
         || isAdmin());

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll(['userId', 'branchId', 'status', 'frequencyDays']);

      // Customer can pause/resume/cancel their own subscription;
      // staff can do everything within their branch.
      allow update: if (
        isPharmacistForBranch(resource.data.branchId)
        || isAdmin()
        || (isOwner(resource.data.userId)
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'pausedUntil', 'frequencyDays', 'updatedAt']))
      );

      allow delete: if isAdmin();
    }

    // ── Consultations (v1.5 — pharmacist consult booking) ───
    match /consultations/{consultId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid
         || resource.data.pharmacistId == request.auth.uid
         || isPharmacistForBranch(resource.data.branchId)
         || isAdmin());

      // Customer books a consult — pharmacistId, slotTime, branchId required
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll(['userId', 'branchId', 'pharmacistId', 'scheduledAt', 'status']) &&
        request.resource.data.status == 'pending';

      allow update: if (
        isPharmacistForBranch(resource.data.branchId)
        || isAdmin()
        || (isOwner(resource.data.userId)
            && request.resource.data.status == 'cancelled'
            && resource.data.status in ['pending', 'confirmed'])
      );

      allow delete: if isAdmin();
    }

    // ── Consult slots (pharmacist availability, v1.5) ───────
    match /consult_slots/{slotId} {
      // Customers can read available slots (anyone can browse the calendar)
      allow read: if true;
      // Only staff can create/modify slot availability
      allow write: if isStaff();
    }

    // ── Consent grants (v2-ready, v1 inert) ─────────────────
    // Document ID convention: {grantedByUserId}_{grantedToUserId}_{scope}
    // This makes the existence-check in hasConsentFrom() O(1).
    match /consent_grants/{grantId} {
      allow read: if isAuthenticated() &&
        (resource.data.grantedByUserId == request.auth.uid
         || resource.data.grantedToUserId == request.auth.uid
         || isAdmin());

      // Only the patient (grantedByUserId) can create or revoke their own grants.
      // Cannot impersonate another patient by setting grantedByUserId to someone else.
      allow create: if isAuthenticated() &&
        request.resource.data.grantedByUserId == request.auth.uid &&
        request.resource.data.keys().hasAll(['grantedByUserId', 'grantedToUserId', 'scope', 'grantedAt']);

      allow update: if isAuthenticated() &&
        resource.data.grantedByUserId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['revokedAt', 'updatedAt']);

      allow delete: if false; // Never hard-delete. Use revokedAt for audit trail.
    }

    // ── OTP attempts (brute-force protection) ───────────────
    // Written by the sendOtp Cloud Function only. Never readable from client.
    match /otp_attempts/{attemptId} {
      allow read: if false;
      allow write: if false; // Cloud Functions only (admin SDK bypass)
    }

    // ── Notifications ────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    // ── Banners / Health Tips / Promo Codes / Stats ─────────
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /healthTips/{tipId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promoCodes/{code} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /stats/{statId} {
      allow read: if isStaff();
      allow write: if false; // Cloud Functions only
    }

    // ── Branches (v2 multi-store config) ────────────────────
    // Read by app to show branch selector; write by admin only.
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
