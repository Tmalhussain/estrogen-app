PORT=8787

# Database. SQLite for local dev; Postgres in production.
#   DATABASE_URL=./data.db
#   DATABASE_URL=postgres://user:pass@host:5432/db          # Cloud SQL / Neon / Supabase / Render
DATABASE_URL=./data.db

# JWT for the mobile session token. Use a real 32+ char random string in prod.
JWT_SECRET=change-me-to-a-32-char-random-string
JWT_EXPIRES_IN=7d

# SMS provider for the OTP flow.
# - "console" (default) logs the OTP to the server log so you can copy it
#   during dev without burning real SMS credits.
# - "unifonic" sends real SMS via Unifonic. Set the three UNIFONIC_* vars
#   below before flipping to this in production.
SMS_PROVIDER=console
UNIFONIC_APP_SID=
UNIFONIC_SENDER_ID=Estrogen
UNIFONIC_API_URL=https://api.unifonic.com/rest/SMS/messages

# Firebase Admin (optional). When set, /auth/verify-otp also returns a
# Firebase custom token so the mobile app can sign into Firebase Auth and
# share the same uid as our Postgres users.id row across FCM, Cloud
# Storage, RTDB, etc. Leave blank in dev to skip Firebase entirely.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Multi-line; \n in the env value is converted to real newlines at runtime.
FIREBASE_PRIVATE_KEY=
# Or, set GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json instead of the
# three vars above.

